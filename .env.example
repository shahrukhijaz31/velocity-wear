# ---------------------------------------------------------------------------
# Velocity Wear — environment variables
# ---------------------------------------------------------------------------
# On Vercel: add a Postgres store (Project -> Storage -> Create -> Postgres).
# Vercel auto-injects POSTGRES_* vars into every deployment. You only need to
# add AUTH_SECRET manually (Project -> Settings -> Environment Variables).
#
# For LOCAL development: run `vercel env pull .env` after connecting the DB,
# or copy the values from the Vercel Storage ".env.local" tab into a `.env`.
# ---------------------------------------------------------------------------

# Vercel Postgres (Neon) — used by Prisma.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Secret used to sign admin session cookies (required for login).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
